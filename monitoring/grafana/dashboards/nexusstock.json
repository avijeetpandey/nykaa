{
  "title": "NexusStock — Application Metrics",
  "uid": "nexusstock-main",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "tags": ["nexusstock", "spring-boot"],
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"nykaa\"}[1m])) by (uri, method, status)",
          "legendFormat": "{{method}} {{uri}} [{{status}}]",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP P99 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"nykaa\"}[1m])) by (le, uri)) * 1000",
          "legendFormat": "p99 {{uri}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"nykaa\",status=~\"5..\"}[1m])) by (uri)",
          "legendFormat": "5xx {{uri}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 4,
      "title": "JVM Heap Used (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"nykaa\",area=\"heap\"} / 1048576",
          "legendFormat": "{{id}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 5,
      "title": "HikariCP Active Connections",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"nykaa\"}",
          "legendFormat": "Active",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 6,
      "title": "HikariCP Pending Threads",
      "type": "stat",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "hikaricp_connections_pending{application=\"nykaa\"}",
          "legendFormat": "Pending",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 7,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "kafka_consumer_fetch_manager_records_lag{application=\"nykaa\"}",
          "legendFormat": "{{topic}} [{{partition}}]",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 8,
      "title": "Redis Command Latency P99 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(spring_data_redis_command_duration_seconds_bucket{application=\"nykaa\"}[1m])) by (le, command)) * 1000",
          "legendFormat": "p99 {{command}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 9,
      "title": "JVM CPU Usage",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 24, "w": 6, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"nykaa\"}",
          "legendFormat": "CPU",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 10,
      "title": "Uptime (seconds)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 24, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "process_uptime_seconds{application=\"nykaa\"}",
          "legendFormat": "Uptime",
          "datasource": "Prometheus"
        }
      ]
    }
  ]
}
